#!/usr/bin/make -f
# debian/rules - Build rules for hp-scanner-driver
# Maintainer: c0xc
#
# =============================================================================
# BUG FIX: /etc/sane.d/dll.conf conflict with libsane-common
# =============================================================================
# PROBLEM:
#   Upstream HPLIP's `make install` writes directly to /etc/sane.d/dll.conf,
#   which is owned by the libsane-common package. This causes dpkg errors:
#   "trying to overwrite '/etc/sane.d/dll.conf', which is also in package libsane-common"
#
# WHY THIS IS WRONG:
#   - dll.conf is a shared system config file managed by libsane-common
#   - Multiple packages writing to it causes file conflicts
#   - This is NOT best practice for modern SANE installations
#
# SOLUTION:
#   Modern SANE supports drop-in configs in /etc/sane.d/dll.d/*.conf
#   - Each package creates its own .conf file in dll.d/
#   - SANE reads both dll.conf AND all dll.d/*.conf files
#   - No file conflicts between packages
#
# IMPLEMENTATION:
#   1. Remove dll.conf and dll.d/ from the package build (below)
#   2. Use postinst to create /etc/sane.d/dll.d/hpaio.conf at install time
#   3. Use prerm to remove it on uninstall
#   4. Declare hpaio.conf in debian/conffiles
#
# NOTE: The rm commands below remove files from the PACKAGE STAGING DIRECTORY
#       (debian/hp-scanner-driver/), NOT from the user's actual /etc/sane.d/.
#       The user's existing dll.conf is never touched by this package.
# =============================================================================

export DH_VERBOSE = 1

%:
	dh $@ --with python3 --buildsystem=autoconf

override_dh_auto_configure:
	dh_auto_configure -- \
		--disable-qt4 \
		--enable-qt5 \
		--disable-fax-build \
		--disable-static \
		--with-mimetype=application/vnd.hp-hpipl \
		--enable-python3 \
		--disable-python2 \
		--with-python3=/usr/bin/python3

override_dh_auto_install:
	dh_auto_install -- DESTDIR=$(CURDIR)/debian/hp-scanner-driver
	# Remove dll.conf and dll.d - we manage them in postinst/prerm
	rm -f $(CURDIR)/debian/hp-scanner-driver/etc/sane.d/dll.conf
	rm -rf $(CURDIR)/debian/hp-scanner-driver/etc/sane.d/dll.d

override_dh_strip:
	dh_strip --dbgsym-migration='hp-scanner-driver-dbgsym (<< 3.25.8)'

override_dh_shlibdeps:
	dh_shlibdeps -- -dpython3:Depends

override_dh_installdeb:
	dh_installdeb

override_dh_python3:
	dh_python3

override_dh_installdocs:
	dh_installdocs
	dh_installexamples

override_dh_installinit:
	dh_installinit --no-start

override_dh_systemd_enable:
	dh_systemd_enable --no-enable

override_dh_systemd_start:
	dh_systemd_start --no-start
