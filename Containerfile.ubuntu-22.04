# Containerfile for building hp-scanner-driver (Ubuntu 22.04 / Mint 21.x)
# Maintainer: c0xc
# Build: podman build -t hp-scanner-driver-ubuntu-22.04-builder -f Containerfile.ubuntu-22.04 .
# Run:   podman run --rm -v ./output:/build/output hp-scanner-driver-ubuntu-22.04-builder [VERSION|latest]
#
# Target: Ubuntu 22.04 LTS (Jammy) and Linux Mint 21.x
# Note: Python 3 only - python2 is NOT installed to avoid shebang issues

FROM ubuntu:jammy

RUN apt-get update && apt-get install -y \
    build-essential autoconf automake libtool pkg-config \
    libcups2-dev libcupsimage2-dev libusb-1.0-0-dev \
    libsane-dev libjpeg-dev libdbus-1-dev \
    libavahi-client-dev libavahi-common-dev libavahi-core-dev \
    libsnmp-dev python3-dev python3-pyqt5 python3-sip \
    gawk python-is-python3 python3-distutils ghostscript cups-filters cups-bsd \
    curl dnsutils perl iproute2 netcat-openbsd ca-certificates lsb-release \
    unzip xz-utils file bzip2 gzip \
    devscripts equivs wget patch gnupg dirmngr \
    && rm -rf /var/lib/apt/lists/* \
    && rm -f /usr/bin/python2 2>/dev/null || true

# Ensure python points to python3
RUN update-alternatives --install /usr/bin/python python /usr/bin/python3 100 2>/dev/null || ln -sf python3 /usr/bin/python

WORKDIR /build
COPY packages/ /build/packages/
COPY VERSION /build/VERSION

RUN printf '#!/bin/bash\nVERSION=${1:-latest}\nif [ "$VERSION" = "latest" ]; then\n    VERSION=$(cat /build/VERSION)\nfi\ncd /build/packages\n./build-deb.sh $VERSION ubuntu-22.04\n' > /build/build.sh && chmod +x /build/build.sh

ENTRYPOINT ["/build/build.sh"]
